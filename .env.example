# Copy this file to .env.local and fill in every value marked ✅ before running
# the project locally or deploying. Variables marked "Ingest only" are only
# needed when running the data-pipeline scripts (scripts/ingest-*.ts).

# ─── Database (Prisma / Supabase Postgres) ───────────────────────────────────
# Supabase → Settings → Database → Connection string
# Use the Transaction (pooled) URL for DATABASE_URL and the Session (direct)
# URL for DIRECT_URL (required by Prisma migrate).
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true  # ✅
DIRECT_URL=postgresql://postgres.xxxx:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres                  # ✅

# ─── Supabase ────────────────────────────────────────────────────────────────
# Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co          # ✅
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...                   # ✅
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...                       # ✅ — never expose client-side

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...                              # ✅
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...             # ✅

# ─── Stripe Price IDs ─────────────────────────────────────────────────────────
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_...

# Stripe Dashboard → Products → FamilyRoam Pro → Pricing → Price ID
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_...                  # ✅

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000                  # ✅ (set to your production URL on Vercel)
ADMIN_EMAIL=you@example.com                                # ✅ — grants access to /admin

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# resend.com → API Keys → Create API Key
RESEND_API_KEY=re_...                                      # ✅

# ─── Images (Unsplash) ───────────────────────────────────────────────────────
# Server-side key used by seed/ingest scripts to fetch permanent CDN image URLs.
UNSPLASH_ACCESS_KEY=your-unsplash-access-key
# Client-side key used as fallback in the UI when a city has no stored imageUrl.
NEXT_PUBLIC_UNSPLASH_ACCESS_KEY=your-unsplash-access-key
